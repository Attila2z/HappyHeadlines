{
  "__inputs": [],
  "__requires": [
    { "type": "panel", "id": "gauge",      "name": "Gauge",       "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Cache hit ratios and throughput for ArticleCache and CommentCache",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "Article Cache",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Fraction of GET /articles/{continent}/{id} requests served from Redis over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "color":  { "mode": "thresholds" },
          "max":    1,
          "min":    0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "green",  "value": 0.8  }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "orientation":    "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Article Cache Hit Ratio (5 m)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(article_cache_hits_total[5m])) / (sum(rate(article_cache_hits_total[5m])) + sum(rate(article_cache_misses_total[5m])))",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Article cache hits and misses per second over time.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Article Cache Hits vs Misses",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "sum(rate(article_cache_hits_total[1m]))",
          "legendFormat": "hits / s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "sum(rate(article_cache_misses_total[1m]))",
          "legendFormat": "misses / s",
          "refId": "B"
        }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 11,
      "title": "Comment Cache",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Fraction of GET /comments/article/{id} requests served from Redis over the last 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "color":  { "mode": "thresholds" },
          "max":    1,
          "min":    0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "yellow", "value": 0.5  },
              { "color": "green",  "value": 0.8  }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "orientation":    "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Comment Cache Hit Ratio (5 m)",
      "type": "gauge",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(comment_cache_hits_total[5m])) / (sum(rate(comment_cache_hits_total[5m])) + sum(rate(comment_cache_misses_total[5m])))",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Comment cache hits and misses per second over time.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 10 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "title": "Comment Cache Hits vs Misses",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "sum(rate(comment_cache_hits_total[1m]))",
          "legendFormat": "hits / s",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr":         "sum(rate(comment_cache_misses_total[1m]))",
          "legendFormat": "misses / s",
          "refId": "B"
        }
      ]
    }

  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "tags": ["happyheadlines", "cache"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "HappyHeadlines — Cache Hit Ratios",
  "uid": "hh-cache-dashboard",
  "version": 1
}
